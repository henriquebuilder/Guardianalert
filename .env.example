# GuardianAlert — copy values into your local secrets file.
# Cloudflare Workers (production): Dashboard → Workers → your worker → Settings → Variables / Secrets
# Local dev with Wrangler: create code/.dev.vars with the same keys (Wrangler loads .dev.vars automatically).

# Required for JWT sessions (admin + app users)
JWT_SECRET=

# Twilio SMS (optional; if unset, alert SMS runs in simulation mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
